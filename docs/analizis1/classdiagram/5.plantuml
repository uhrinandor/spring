    class StoneSplasher implements IHead, ShopItem
    {
    +key(): string
    +interact(field: IField, inventory: Inventory): bool
    +price(): int
    +apply(ctx: PurchaseContext, amount: int): void
    + limit(): int
    }


class Biokerosene implements IInventoryItem, ShopItem
    {
    +key(): string
    +price(): int
    +apply(ctx: PurchaseContext, amount: int): void
    + limit(): int
    }

class Stone implements IInventoryItem, ShopItem
    {
    +key(): string
    +price(): int
    +apply(ctx: PurchaseContext, amount: int): void
    + limit(): int
    }

   interface ShopItem{
       + price(): int
       + apply(ctx: PurchaseContext, amount: int): void
   }
@enduml